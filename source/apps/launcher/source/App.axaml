<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ECS3DLauncher.App"
             RequestedThemeVariant="Dark">

    <!-- App-level composition only. Palette, fonts, and control themes live in
         Shared/Resources; style selectors live in Shared/Styles. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/source/Shared/Resources/Theme.axaml" />
                <ResourceInclude Source="/source/Shared/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/source/Shared/Styles/AppStyles.axaml" />
    </Application.Styles>

</Application>
